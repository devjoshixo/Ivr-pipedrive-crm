# Copy to .env for local development (dotenv loads it). NEVER commit the real .env.

# --- Server ---
PORT=3000
NODE_ENV=development

# Comma-separated origins allowed to call this backend (the Pipedrive app domains).
# e.g. https://your-app.example.com,https://marketplace-public.pipedrive.com
ALLOWED_ORIGINS=

# --- Database (MariaDB / MySQL) ---
DATABASE_URL=mysql://user:password@localhost:3306/ivr_pipedrive
# Prefix for this app's tables in a shared database (e.g. pipedrive_). Leave empty
# for a dedicated database. URL-encode special chars in the password above.
DB_TABLE_PREFIX=

# --- IVR API ---
IVR_BASE_URL=https://api.ivrsolutions.in
# Companion Chrome extension (softphone / click-to-dial). Shown on the settings page
# so agents can install it. Defaults to the published Web Store listing.
CHROME_EXTENSION_URL=https://chromewebstore.google.com/detail/ivr-solutions-webrtc-soft/keffpnadhppdelceioccednhjdghmbfi
# Background poll interval for /v1/all_call_logs (ms). Default 30000 (30s), floor 10000.
SYNC_INTERVAL_MS=30000
# What to do when a call's number matches no Pipedrive person:
#   floating (default) = log the call with no contact link (no CRM clutter; still callable)
#   person             = create a Person and link the call
#   lead               = create a Person + Lead and link the call
#   skip               = don't log the call at all
NO_MATCH_POLICY=floating
# Auto-prune the dedupe ledger (synced_calls) — rows older than N days are deleted
# daily. Default 30. Duplicate-safe (it skips any company whose cursor is held by an
# unresolved failure). Set 0 to disable and keep every row.
SYNCED_CALLS_RETENTION_DAYS=30
# Per-company rate limit on team-facing API endpoints
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
# 32-byte key for sealing IVR tokens at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IVR_TOKEN_ENC_KEY=

# --- Pipedrive OAuth ---
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=
# Must exactly match the callback URL registered in the Pipedrive Developer Hub.
PIPEDRIVE_REDIRECT_URI=http://localhost:3000/oauth/callback
# Optional: secret for signing the OAuth state (CSRF). Defaults to the client secret.
OAUTH_STATE_SECRET=
# Optional: public base URL of this backend (used in redirects behind a proxy).
PUBLIC_BASE_URL=http://localhost:3000
