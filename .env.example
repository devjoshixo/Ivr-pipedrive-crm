# Copy to .env for local development (dotenv loads it). NEVER commit the real .env.

# --- Server ---
PORT=3000
NODE_ENV=development

# Comma-separated origins allowed to call this backend (the Pipedrive app domains).
# e.g. https://your-app.example.com,https://marketplace-public.pipedrive.com
ALLOWED_ORIGINS=

# --- Postgres ---
DATABASE_URL=postgres://user:password@localhost:5432/ivr_pipedrive

# --- IVR API ---
IVR_BASE_URL=https://api.ivrsolutions.in
# 32-byte key for sealing IVR tokens at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IVR_TOKEN_ENC_KEY=

# --- Pipedrive OAuth ---
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=
# Must exactly match the callback URL registered in the Pipedrive Developer Hub.
PIPEDRIVE_REDIRECT_URI=http://localhost:3000/oauth/callback
# Optional: secret for signing the OAuth state (CSRF). Defaults to the client secret.
OAUTH_STATE_SECRET=
# Optional: public base URL of this backend (used in redirects behind a proxy).
PUBLIC_BASE_URL=http://localhost:3000
